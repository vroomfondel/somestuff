# Uptime-Kuma export/import — credentials.
# Copy to uptimekuma.local.env (gitignored via *.local.*) and fill in:
#   cp uptimekumastuff/uptimekuma.env.example uptimekumastuff/uptimekuma.local.env
#
# The script loads this file itself (python-dotenv); no `set -a` needed. Real
# environment variables take precedence, as do --username / --password.
#
# NOTE: the Socket.IO login does NOT accept API keys — use a real user account.

UPTIME_KUMA_USERNAME=admin
UPTIME_KUMA_PASSWORD=CHANGE_ME
