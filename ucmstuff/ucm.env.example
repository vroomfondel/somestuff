# Coordinated UCM6204 monitor + control — environment configuration.
# Copy to ucm.local.env (gitignored via *.local.*), fill in, then:
#   set -a; . ucmstuff/ucm.local.env; set +a
#
# Two entry points consume this file differently:
#   python3 -m ucmstuff.ucm6204_api ...   # full monitor CLI; picks up the
#                                         # UCM_MQTT_* variables below directly,
#                                         # connection settings go via flags
#                                         # (--host "$UCM_HOST" ...)
#   python3 -m ucmstuff.example_router    # reads UCM_HOST/PORT/TRUNKS and the
#                                         # API/WEB credentials; no MQTT
#
# Boolean variables accept true|false (1|0 works as well).

UCM_HOST=ucm.example.lan
UCM_PORT=8089

# HTTPS-API user — used for control actions (accept/refuse/hangup/dial).
# Requires "HTTPS API" enabled + "Call Control" on the UCM (API Configuration).
UCM_API_USER=apiuser
UCM_API_PASSWORD=CHANGE_ME

# Web user — used for the WebSocket event stream.
# NOTE: the API user does NOT work on the WebSocket; use a (limited) web user.
UCM_WEB_USER=webuser
UCM_WEB_PASSWORD=CHANGE_ME

# Space-separated inbound trunk name(s) to route incoming calls for.
# Must match the event's inbound_trunk_name (may differ from the trunk_name in
# listVoIPTrunk!). Empty = monitor only, no routing.
UCM_TRUNKS=MyTrunk

# ── MQTT bridge (optional, default OFF; ucm6204_api CLI only) ────────────────
# Publish events to <base>/events/<eventname> and parsed incoming calls to
# <base>/calls/<trunk>/incoming (per inbound trunk). Enable per env here or
# override on the CLI (--mqtt).
UCM_MQTT_ENABLE=false
UCM_MQTT_HOST=mosquitto.mosquitto.svc.cluster.local
UCM_MQTT_PORT=1883
UCM_MQTT_USER=
UCM_MQTT_PASSWORD=
UCM_MQTT_BASE_TOPIC=ucm6204
# Accept accept/refuse/hangup commands on <base>/cmd/# (needs UCM_API_USER).
UCM_MQTT_COMMANDS=false

# TLS to the broker (default OFF). Brokers usually listen on 8883 for TLS —
# the port is NOT switched automatically, set UCM_MQTT_PORT accordingly.
UCM_MQTT_TLS=false
# CA certificate path; empty = system CA store (fine for Let's-Encrypt brokers).
# NOTE: must be a certificate the broker actually presents — an ingress
# (e.g. Traefik) answering with its default cert cannot be verified; give the
# broker route a proper hostname + certificate instead.
UCM_MQTT_TLS_CA=
# Client certificate + key for mutual TLS (both or neither).
UCM_MQTT_TLS_CERT=
UCM_MQTT_TLS_KEY=
# Skip hostname verification (self-signed certs) — still encrypted, but
# MITM-able, and it does NOT bypass chain verification. Last resort only.
UCM_MQTT_TLS_INSECURE=false
