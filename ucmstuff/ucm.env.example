# Coordinated UCM6204 monitor + control — environment configuration.
# Copy to ucm.env.local (gitignored via *.local.*), fill in, then:
#   set -a; . ucmstuff/ucm.env.local; set +a
#   python3 -m ucmstuff.example_router

UCM_HOST=ucm.example.lan
UCM_PORT=8089

# HTTPS-API user — used for control actions (accept/refuse/hangup/dial).
# Requires "HTTPS API" enabled + "Call Control" on the UCM (API Configuration).
UCM_API_USER=apiuser
UCM_API_PASSWORD=CHANGE_ME

# Web user — used for the WebSocket event stream.
# NOTE: the API user does NOT work on the WebSocket; use a (limited) web user.
UCM_WEB_USER=webuser
UCM_WEB_PASSWORD=CHANGE_ME

# Space-separated inbound trunk name(s) to route incoming calls for.
# Must match the event's inbound_trunk_name (may differ from the trunk_name in
# listVoIPTrunk!). Empty = monitor only, no routing.
UCM_TRUNKS=MyTrunk
