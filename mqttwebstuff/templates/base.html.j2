<!doctype html>
<html lang="de" data-theme="dark">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <link rel="stylesheet" href="/static/pico.min.css">
  <style>
    /* Board grid on top of PicoCSS; everything mqttweb-specific is prefixed. */
    #board {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(21rem, 1fr));
      gap: 1rem;
      align-items: start;
    }
    .mqttweb-panel {
      margin: 0;
      padding: 1rem;
      border: 1px solid var(--pico-muted-border-color);
      border-radius: var(--pico-border-radius);
      background: var(--pico-card-background-color);
    }
    .mqttweb-panel-plain { border: none; padding: 0; background: none; }
    .mqttweb-panel > h2 {
      font-size: 1rem;
      margin-bottom: 0.75rem;
      border-bottom: 1px solid var(--pico-muted-border-color);
      padding-bottom: 0.35rem;
    }
    .mqttweb-panel article { margin: 0 0 0.75rem 0; padding: 0.6rem 0.8rem; }
    .mqttweb-panel article:last-child { margin-bottom: 0; }
    .mqttweb-empty { color: var(--pico-muted-color); font-style: italic; margin: 0; }
    .mqttweb-group-box {
      border: 1px solid var(--pico-muted-border-color);
      border-radius: var(--pico-border-radius);
      padding: 0.6rem 0.8rem;
      margin-bottom: 0.75rem;
    }
    .mqttweb-group-box:last-child { margin-bottom: 0; }
    .mqttweb-group-box article { padding-left: 0; padding-right: 0; }
    .mqttweb-group {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--pico-muted-color);
      margin: 0 0 0.4rem 0;
      border-bottom: 1px solid var(--pico-muted-border-color);
      padding-bottom: 0.3rem;
    }
    .mqttweb-item pre {
      margin: 0.25rem 0 0 0;
      padding: 0.5rem;
      font-size: 0.75rem;
      max-height: 16rem;
      overflow: auto;
    }
    .mqttweb-topic { color: var(--pico-muted-color); font-size: 0.7rem; word-break: break-all; }
    /* Hierarchical generic view: one indented row per topic segment. */
    .mqttweb-tree-row { font-size: 0.85rem; padding: 0.05rem 0; }
    .mqttweb-tree-branch { color: var(--pico-muted-color); }
    .mqttweb-tree-label { font-weight: 600; }
    .mqttweb-tree-branch .mqttweb-tree-label { font-weight: 500; }
    .mqttweb-tree-row code { padding: 0.05rem 0.35rem; font-size: 0.8rem; }
    .mqttweb-tree-row pre {
      margin: 0.2rem 0 0.3rem 0;
      padding: 0.4rem;
      font-size: 0.72rem;
      max-height: 14rem;
      overflow: auto;
    }
    .mqttweb-tree-details summary { cursor: pointer; }
    .mqttweb-tree-details summary small { color: var(--pico-muted-color); }
    /* Anchor self-links: look like plain labels, reveal a # on hover; a
       targeted element gets highlighted after the jump. */
    .mqttweb-anchor { color: inherit; text-decoration: none; }
    .mqttweb-anchor:hover { text-decoration: underline dotted; }
    .mqttweb-anchor:hover::after { content: " #"; color: var(--pico-muted-color); }
    /* Standalone # mark (rows whose label cannot be a link, e.g. <summary>). */
    .mqttweb-tree-row { position: relative; }
    .mqttweb-anchor-mark {
      position: absolute;
      right: 0.2rem;
      top: 0.05rem;
      color: var(--pico-muted-color);
      opacity: 0;
    }
    .mqttweb-anchor-mark:hover::after { content: none; }
    .mqttweb-tree-row:hover .mqttweb-anchor-mark { opacity: 1; }
    :target { scroll-margin-top: 0.5rem; }
    .mqttweb-group-box:target, .mqttweb-tree-row:target {
      outline: 2px solid var(--pico-primary);
      outline-offset: 2px;
      border-radius: var(--pico-border-radius);
    }
  </style>
  <script src="/static/htmx.min.js"></script>
  <script src="/static/htmx-ext-sse.js"></script>
  {# Plugins may ship an extra_head.html.j2 (styles, meta) via their template dir. #}
  {% include "extra_head.html.j2" ignore missing %}
</head>
<body hx-ext="sse" sse-connect="/stream">
  <header class="container-fluid">
    <hgroup style="margin: 0.75rem 0;">
      <h1 style="font-size: 1.4rem; margin-bottom: 0;">{{ title }}</h1>
      <p style="margin: 0;"><small>MQTT live stream</small></p>
    </hgroup>
  </header>
  <main class="container-fluid">
    {# 'board' events (a runtime-created panel) swap the whole grid; per-panel
       repaints target the sse-swap divs rendered inside. #}
    <div id="board" sse-swap="board">
      {{ board|safe }}
    </div>
  </main>
  <script>
    // Panel repaints replace the DOM, which would collapse any expanded
    // <details> (tree view JSON). Remember open states by data-tree-id and
    // re-apply them after every htmx swap.
    (function () {
      const openTree = new Set();
      document.addEventListener("toggle", (e) => {
        const id = e.target.dataset && e.target.dataset.treeId;
        if (!id) return;
        if (e.target.open) { openTree.add(id); } else { openTree.delete(id); }
      }, true);
      document.body.addEventListener("htmx:afterSwap", () => {
        document.querySelectorAll("details[data-tree-id]").forEach((d) => {
          if (openTree.has(d.dataset.treeId)) { d.open = true; }
        });
      });
    })();
  </script>
</body>
</html>
