<!doctype html>
<html lang="de" data-theme="dark">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <link rel="stylesheet" href="/static/pico.min.css">
  <style>
    /* Board grid on top of PicoCSS; everything mqttweb-specific is prefixed. */
    #board {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(21rem, 1fr));
      gap: 1rem;
      align-items: start;
    }
    .mqttweb-panel {
      margin: 0;
      padding: 1rem;
      border: 1px solid var(--pico-muted-border-color);
      border-radius: var(--pico-border-radius);
      background: var(--pico-card-background-color);
    }
    .mqttweb-panel-plain { border: none; padding: 0; background: none; }
    .mqttweb-panel > h2 {
      font-size: 1rem;
      margin-bottom: 0.75rem;
      border-bottom: 1px solid var(--pico-muted-border-color);
      padding-bottom: 0.35rem;
    }
    .mqttweb-panel article { margin: 0 0 0.75rem 0; padding: 0.6rem 0.8rem; }
    .mqttweb-panel article:last-child { margin-bottom: 0; }
    .mqttweb-empty { color: var(--pico-muted-color); font-style: italic; margin: 0; }
    .mqttweb-group-box {
      border: 1px solid var(--pico-muted-border-color);
      border-radius: var(--pico-border-radius);
      padding: 0.6rem 0.8rem;
      margin-bottom: 0.75rem;
    }
    .mqttweb-group-box:last-child { margin-bottom: 0; }
    .mqttweb-group-box article { padding-left: 0; padding-right: 0; }
    .mqttweb-group {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--pico-muted-color);
      margin: 0 0 0.4rem 0;
      border-bottom: 1px solid var(--pico-muted-border-color);
      padding-bottom: 0.3rem;
    }
    .mqttweb-item pre {
      margin: 0.25rem 0 0 0;
      padding: 0.5rem;
      font-size: 0.75rem;
      max-height: 16rem;
      overflow: auto;
    }
    .mqttweb-topic { color: var(--pico-muted-color); font-size: 0.7rem; word-break: break-all; }
  </style>
  <script src="/static/htmx.min.js"></script>
  <script src="/static/htmx-ext-sse.js"></script>
  {# Plugins may ship an extra_head.html.j2 (styles, meta) via their template dir. #}
  {% include "extra_head.html.j2" ignore missing %}
</head>
<body hx-ext="sse" sse-connect="/stream">
  <header class="container-fluid">
    <hgroup style="margin: 0.75rem 0;">
      <h1 style="font-size: 1.4rem; margin-bottom: 0;">{{ title }}</h1>
      <p style="margin: 0;"><small>MQTT live stream</small></p>
    </hgroup>
  </header>
  <main class="container-fluid">
    {# 'board' events (a runtime-created panel) swap the whole grid; per-panel
       repaints target the sse-swap divs rendered inside. #}
    <div id="board" sse-swap="board">
      {{ board|safe }}
    </div>
  </main>
</body>
</html>
