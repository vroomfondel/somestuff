{# One row of the hierarchical generic view. data: label, depth, branch, value.
   Indentation encodes the topic hierarchy; branch rows are structure-only.
   Every row carries a stable anchor id (/#t-<topic-slug>) for deep links. #}
<div class="mqttweb-tree-row{% if data.branch %} mqttweb-tree-branch{% endif %}" id="t-{{ key | anchor }}" style="margin-left: {{ data.depth * 1.1 }}rem;">
  {% if data.branch %}
  <a class="mqttweb-anchor" href="#t-{{ key | anchor }}"><span class="mqttweb-tree-label">{{ data.label }}/</span></a>
  {% elif data.value is string or data.value is number or data.value is boolean %}
  <a class="mqttweb-anchor" href="#t-{{ key | anchor }}"><span class="mqttweb-tree-label">{{ data.label }}</span></a> <code>{{ data.value }}</code>
  {% elif data.value is none %}
  <a class="mqttweb-anchor" href="#t-{{ key | anchor }}"><span class="mqttweb-tree-label">{{ data.label }}</span></a> <code>null</code>
  {% else %}
  {# No self-link inside <summary> — a nested <a> would fight the toggle; a
     separate # mark at the row's right edge makes the anchor clickable. #}
  <a class="mqttweb-anchor mqttweb-anchor-mark" href="#t-{{ key | anchor }}" title="{{ key }}">#</a>
  <details class="mqttweb-tree-details" data-tree-id="{{ key }}">
    <summary><span class="mqttweb-tree-label">{{ data.label }}</span> <small>{…}</small></summary>
    <pre>{{ data.value | tojson(indent=2) }}</pre>
  </details>
  {% endif %}
</div>
