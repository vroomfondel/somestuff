# mqttweb live stream viewer — environment configuration.
# Copy to mqttweb.local.env (gitignored via *.local.*), fill in, then:
#   python3 -m mqttwebstuff.serve
# (serve.py auto-loads mqttweb.local.env from the current working directory
#  AND from the package dir; the CWD file wins over the package-dir file, real
#  environment variables win over both files, CLI options over all.)

# ── mapper plugin ────────────────────────────────────────────────────────────
# Path to the mapper plugin .py file (see plugin_api.py for the contract).
# Empty = generic view: every message from MQTTWEB_TOPICS as a JSON card.
MQTTWEB_MAPPER=mqttwebstuff/plugins/oepnv_view.py
# Generic view only: comma-separated subscribe patterns and the seconds until
# an unrefreshed card disappears (0 = keep forever). Ignored with a mapper.
MQTTWEB_TOPICS=#
MQTTWEB_ITEM_TTL=900
# Page title override; empty = the plugin's TITLE.
MQTTWEB_TITLE=

# Plugin-specific settings are plain environment variables the plugin reads
# itself. The oepnv_view plugin honours the publisher's base-topic variable
# (default "oepnv"; multi-level bases like "home/oepnv" work):
#OEPNV_MQTT_BASE_TOPIC=oepnv

# ── web server ───────────────────────────────────────────────────────────────
MQTTWEB_LISTEN_HOST=0.0.0.0
MQTTWEB_LISTEN_PORT=8080
# Reject new connections with 503 above N concurrent ones (0 = unlimited).
# Every open browser tab holds one SSE stream and a page load briefly needs
# several slots — size generously (100+), never per expected user.
MQTTWEB_LIMIT_CONCURRENCY=0

# ── MQTT broker ──────────────────────────────────────────────────────────────
MQTTWEB_MQTT_HOST=mosquitto.mosquitto.svc.cluster.local
MQTTWEB_MQTT_PORT=1883
# Empty user = anonymous.
MQTTWEB_MQTT_USER=
MQTTWEB_MQTT_PASSWORD=

# TLS (default OFF). Brokers usually listen on 8883 for TLS — the port is NOT
# switched automatically, set MQTTWEB_MQTT_PORT accordingly.
MQTTWEB_MQTT_TLS=false
# CA certificate path; empty = system CA store (fine for Let's-Encrypt brokers).
# NOTE: must be a certificate the broker actually presents — an ingress
# (e.g. Traefik) answering with its default cert cannot be verified; give the
# broker route a proper hostname + certificate instead.
MQTTWEB_MQTT_TLS_CA=
# Client certificate + key for mutual TLS (both or neither).
MQTTWEB_MQTT_TLS_CERT=
MQTTWEB_MQTT_TLS_KEY=
# Skip hostname verification (self-signed certs) — still encrypted, but
# MITM-able, and it does NOT bypass chain verification. Last resort only.
MQTTWEB_MQTT_TLS_INSECURE=false

# DEBUG logging (incl. uvicorn access log).
MQTTWEB_VERBOSE=false
