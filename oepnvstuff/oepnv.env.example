# GTFS-realtime coverage checker — environment configuration.
# Copy to oepnv.local.env (gitignored via *.local.*), fill in, then:
#   set -a; . oepnvstuff/oepnv.local.env; set +a
#   python3 -m oepnvstuff.check_realtime --watch
# (check_realtime.py auto-loads oepnv.local.env from the current working
#  directory AND from the package dir; the CWD file wins over the package-dir
#  file, real environment variables win over both files, CLI options over all.)

# Feed sources (URLs or local file paths).
OEPNV_STATIC_URL=https://download.gtfs.de/germany/nv_free/latest.zip
OEPNV_REALTIME_URL=https://realtime.gtfs.de/realtime-free.pb

# Target lines (route_short_name), comma/space separated, and the station(s)
# (substring match against stop_name, case-insensitive; several stations
# ';'-separated, e.g. "Blankenese;Ellerbek" — NOT comma, stop names contain commas).
OEPNV_LINES=1,12,22,189
OEPNV_STATION=Blankenese

# Departure board: report the next N departures per line+direction, with
# realtime delay when available ("1 Richtung S Rissen: in 2 min (+80s)").
# With MQTT enabled they are published to <base>/departures (full document)
# and <base>/departures/<line>/<stop>/<direction> (per group, ASCII-simplified
# topic segments).
OEPNV_ENABLE_DEPARTURES=false
OEPNV_DEPARTURES_COUNT=3
# Look-ahead window in hours (48 is plenty: a fresh static zip appears within
# that window, and every restart looks 48h ahead again).
OEPNV_DEPARTURES_HORIZON_HOURS=48
# Optional geographic filter 'lat,lon,radius_km' — GTFS has no postal codes,
# so this disambiguates same-named stations in different towns. Empty = off.
#OEPNV_NEAR=53.563,9.813,3

# Cache directory for the (large) static zip + HTTP validator metadata.
# In k3s, point this at a persistent volume so restarts reuse the download.
OEPNV_CACHE_DIR=.gtfs_cache

# Watch mode: poll loop instead of one-shot check.
OEPNV_WATCH=false
# Poll interval in seconds (gtfs.de updates every ~10s).
OEPNV_INTERVAL=20
# Staleness: feed older than N seconds (0 = off) or N unchanged cycles.
OEPNV_MAX_AGE=120
OEPNV_STALE_CYCLES=6
# Stop the watch loop (exit 2) once the feed is stale — lets k8s restart the pod.
OEPNV_STOP_ON_STALE=false

# ── MQTT bridge (optional, default OFF) ──────────────────────────────────────
# Publish per-cycle status to <base>/status and <base>/lines/<line>/status,
# new service alerts to <base>/alerts and stale transitions to <base>/stale.
# All messages are sent with retain=False (the broker keeps no last value).
# Enable per env here or override on the CLI (--mqtt).
OEPNV_MQTT_ENABLE=false
OEPNV_MQTT_HOST=mosquitto.mosquitto.svc.cluster.local
OEPNV_MQTT_PORT=1883
OEPNV_MQTT_USER=
OEPNV_MQTT_PASSWORD=
OEPNV_MQTT_BASE_TOPIC=oepnv

# TLS (default OFF). Brokers usually listen on 8883 for TLS — the port is NOT
# switched automatically, set OEPNV_MQTT_PORT accordingly.
OEPNV_MQTT_TLS=false
# CA certificate path; empty = system CA store (fine for Let's-Encrypt brokers).
# NOTE: must be a certificate the broker actually presents — an ingress
# (e.g. Traefik) answering with its default cert cannot be verified; give the
# broker route a proper hostname + certificate instead.
OEPNV_MQTT_TLS_CA=
# Client certificate + key for mutual TLS (both or neither).
OEPNV_MQTT_TLS_CERT=
OEPNV_MQTT_TLS_KEY=
# Skip hostname verification (self-signed certs) — still encrypted, but
# MITM-able, and it does NOT bypass chain verification. Last resort only.
OEPNV_MQTT_TLS_INSECURE=false

# DEBUG logging.
OEPNV_VERBOSE=false
