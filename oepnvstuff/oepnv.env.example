# GTFS-realtime coverage checker — environment configuration.
# Copy to oepnv.local.env (gitignored via *.local.*), fill in, then:
#   set -a; . oepnvstuff/oepnv.local.env; set +a
#   python3 -m oepnvstuff.check_realtime --watch
# (check_realtime.py auto-loads oepnv.local.env from the current working
#  directory AND from the package dir; the CWD file wins over the package-dir
#  file, real environment variables win over both files, CLI options over all.)

# Feed sources (URLs or local file paths).
OEPNV_STATIC_URL=https://download.gtfs.de/germany/nv_free/latest.zip
OEPNV_REALTIME_URL=https://realtime.gtfs.de/realtime-free.pb

# Target lines (route_short_name), comma/space separated, and the station
# (substring match against stop_name, case-insensitive).
OEPNV_LINES=1,12,22,189
OEPNV_STATION=Blankenese
# Optional geographic filter 'lat,lon,radius_km' — GTFS has no postal codes,
# so this disambiguates same-named stations in different towns. Empty = off.
#OEPNV_NEAR=53.563,9.813,3

# Cache directory for the (large) static zip + HTTP validator metadata.
# In k3s, point this at a persistent volume so restarts reuse the download.
OEPNV_CACHE_DIR=.gtfs_cache

# Watch mode: poll loop instead of one-shot check.
OEPNV_WATCH=0
# Poll interval in seconds (gtfs.de updates every ~10s).
OEPNV_INTERVAL=20
# Staleness: feed older than N seconds (0 = off) or N unchanged cycles.
OEPNV_MAX_AGE=120
OEPNV_STALE_CYCLES=6
# Stop the watch loop (exit 2) once the feed is stale — lets k8s restart the pod.
OEPNV_STOP_ON_STALE=0

# ── MQTT bridge (optional, default OFF) ──────────────────────────────────────
# Publish per-cycle status to <base>/status and <base>/lines/<line>/status
# (retained), new service alerts to <base>/alerts and stale transitions to
# <base>/stale (transient). Enable per env here or override on the CLI (--mqtt).
OEPNV_MQTT_ENABLE=0
OEPNV_MQTT_HOST=mosquitto.mosquitto.svc.cluster.local
OEPNV_MQTT_PORT=1883
OEPNV_MQTT_USER=
OEPNV_MQTT_PASSWORD=
OEPNV_MQTT_BASE_TOPIC=oepnv

# DEBUG logging.
OEPNV_VERBOSE=0
